# Backend Environment Variables - Example Template
# 
# Environment-specific files (automatically loaded by dotenv):
# - .env.development (loaded when NODE_ENV=development)
# - .env.production (loaded when NODE_ENV=production)
#
# Override files (optional, highest priority):
# - .env.local (overrides all environments, not committed to git)
#
# Copy this file to create your own environment configs

# Server
PORT=3001
NODE_ENV=development

# CORS - comma-separated allowed origins
# In production add your Vercel frontend URL, e.g.:
# CORS_ORIGINS=https://teledesk.vercel.app,https://your-custom-domain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Firebase Admin SDK (Auth only – used by authMiddleware to verify ID tokens)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token

# Supabase (PostgreSQL – messages, users, chats)
# Get these from: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare R2 (file storage)
# Get access keys from: Cloudflare Dashboard → R2 → Manage API tokens
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=teledesk-files
# Public R2 URL (enable via Cloudflare R2 bucket → Public Access)
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# IP Geolocation (optional - for device session location tracking)
# Get free API key from: https://ipinfo.io/signup
IPINFO_API_KEY=your-ipinfo-api-key
