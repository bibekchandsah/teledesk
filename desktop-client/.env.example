# Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# Firebase (Auth only – Google/GitHub/email sign-in; no Firestore/Storage)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Supabase (anon key for Realtime subscriptions only; writes go through backend)
# Get these from: https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

VITE_BACKEND_URL=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001

# WebRTC TURN Server Configuration (optional - for better NAT traversal)
# Free option: openrelay.metered.ca (limited bandwidth)
# Production: Use services like Twilio, Agora, or self-hosted coturn
VITE_TURN_URL=turn:openrelay.metered.ca:80
VITE_TURN_USERNAME=openrelayproject
VITE_TURN_CREDENTIAL=openrelayproject

# Set to true to allow right-click context menu and DevTools (for development)
# ALLOW_DEVTOOLS is read by Electron main process
# VITE_ALLOW_DEVTOOLS is read by the renderer (to disable blur overlay)
ALLOW_DEVTOOLS=false
VITE_ALLOW_DEVTOOLS=false
