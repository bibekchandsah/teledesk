# Frontend Environment Variables - Example Template
# 
# Environment-specific files (automatically loaded):
# - .env.development (loaded during: npm run dev, electron:dev)
# - .env.production (loaded during: npm run build, electron:build)
#
# Override files (optional, highest priority):
# - .env.local (overrides all environments, not committed to git)
#
# Copy this file to create your own environment configs

# Firebase (Auth only – Google/GitHub/email sign-in; no Firestore/Storage)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Supabase (anon key for Realtime subscriptions only; writes go through backend)
# Get these from: https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

VITE_BACKEND_URL=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001

# WebRTC ICE Servers Configuration (JSON array of RTCIceServer objects)
# Example template for multi-server fallback:
VITE_ICE_SERVERS_JSON='[
  { "urls": "stun:stun.l.google.com:19302" },
  { 
    "urls": ["turn:your-turn-server.com"], 
    "username": "your-user", 
    "credential": "your-password" 
  }
]'

# Set to true to allow right-click context menu and DevTools (for development)
# ALLOW_DEVTOOLS is read by Electron main process
# VITE_ALLOW_DEVTOOLS is read by the renderer (to disable blur overlay)
ALLOW_DEVTOOLS=false
VITE_ALLOW_DEVTOOLS=false
