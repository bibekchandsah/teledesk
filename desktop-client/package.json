{
  "name": "teledesk-desktop",
  "version": "1.0.3",
  "description": "TeleDesk Desktop Messaging App",
  "author": {
    "name": "Bibek Chand Sah",
    "email": "bibeksha48@gmail.com"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "electron:dev": "tsc -p tsconfig.electron.json && concurrently \"vite\" \"tsc -p tsconfig.electron.json --watch\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development npx electron .\"",
    "electron:build": "vite build && tsc -p tsconfig.electron.json && electron-builder",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@supabase/supabase-js": "^2.98.0",
    "crypto-js": "^4.2.0",
    "firebase": "^10.12.3",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.24.0",
    "react-zoom-pan-pinch": "^3.7.0",
    "simple-peer": "^9.11.1",
    "socket.io-client": "^4.7.5",
    "uuid": "^10.0.0",
    "zustand": "^4.5.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/simple-peer": "^9.11.8",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/ui": "^4.1.0",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "fast-check": "^4.6.0",
    "jsdom": "^29.0.0",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vite-plugin-pwa": "^0.20.5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0",
    "wait-on": "^7.2.0",
    "workbox-window": "^7.3.0"
  },
  "build": {
    "appId": "com.teledesk.app",
    "productName": "TeleDesk",
    "electronVersion": "31.7.7",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "${productName}.${ext}",
      "icon": "assets/icon.png",
      "signingHashAlgorithms": null,
      "sign": null
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "artifactName": "${productName}.${ext}",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "artifactName": "${productName}.${ext}",
      "icon": "assets/icon.png"
    }
  }
}
